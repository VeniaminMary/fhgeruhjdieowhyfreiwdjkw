import 'package:my_project/my_project.dart' as my_project;
import 'package:characters/characters.dart' as  chars;
import 'dart:io';
import 'dart:math';

void main() {
  var emojis = [
    '\u{1F600}', // радость
    '\u{1F622}', // грусть
    '\u{1F602}', // смех
    '\u{1F615}', // на парах
    '\u{1F34E}', // яблоко
    '\u{2764}', // любовь
    '\u{1F628}', // страх
    '\u{1F634}', // усталость
  ];

  var descriptions = [
    'радость',
    'грусть',
    'смех',
    'на парах',
    'яблоко',
    'любовь',
    'страх',
    'усталость',
  ];

  var energies = [9, 1, 10, 0, 5, 10, 3, 1];

  stdout.write('Введите ваше имя: ');
  String? name = stdin.readLineSync();

  var random = Random();
  int index = random.nextInt(emojis.length);

  String emoji = emojis[index];
  String description = descriptions[index];
  int energy = energies[index];

  print('\nПривет, $name! Твое настроение: $emoji $description (энергия: $energy/10)');

  // юникод для одного эмодзи настроения
  var characters = chars.Characters(emoji);
  var graphemes = characters.toList();
  print('Юникод: ${_formatCodePoints(graphemes)}');



  // анализ сложных эмодзи
  print('\nХотите проанализировать сложные эмодзи? (yes/no)');
  if (stdin.readLineSync()?.toLowerCase() == 'yes') {
    stdout.write('Введите строку с эмодзи: ');
    analyzeEmojiString(stdin.readLineSync()!);
  }
}

// форматирование юникода для списка графем
String _formatCodePoints(List<String> graphemes) {
  List<String> result = [];
  for (var grapheme in graphemes) {
    for (int codePoint in grapheme.runes) {
      String hex = codePoint.toRadixString(16).toUpperCase().padLeft(6, '0');
      result.add('U+$hex');
    }
  }
  return result.join(' ');
}

// анализ строки с эмодзи
void analyzeEmojiString(String input) {
  //Количество 16-битных единиц
  int utf16Units = input.length;
  //Количество кодовых точек 
  int codePoints = input.runes.length;
  //Количество реальных символов
  int graphemeClusters = chars.Characters(input).length;

  print('\nрезультаты');
  print('1: $utf16Units');
  print('2: $codePoints');
  print('3: $graphemeClusters');

  // юникода для каждого символа 
  print('\nюникод каждого символа');
  var characters = chars.Characters(input);
  int idx = 1;
  for (var grapheme in characters) {
    List<String> codePointsList = [];
    for (int cp in grapheme.runes) {
      codePointsList.add('U+${cp.toRadixString(16).toUpperCase().padLeft(6, '0')}');
    }
    print('Символ $idx: "$grapheme" -> ${codePointsList.join(' ')}');
    idx++;
  }
}
