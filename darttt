import 'package:my_project/my_project.dart' as my_project;
import 'package:characters/characters.dart' as my_project;
import 'dart:io';
import 'dart:math';


void main() {
  var emojis = [
    '\u{1F600}', // радость
    '\u{1F622}', // грусть
    '\u{1F602}', // смех
    '\u{1F615}', // на парах
    '\u{1F34E}', // яблоко
    '\u{2764}', // любовь
    '\u{1F628}', // страх
    '\u{1F634}', // усталость
  ];

  var descriptions = [
    'радость',
    'грусть',
    'смех',
    'на парах',
    'яблоко',
    'любовь',
    'страх',
    'усталость',
  ];

  var energies = [9, 1, 10, 0, 5, 10, 3, 1];

  stdout.write('Введите ваше имя: ');
  String? name = stdin.readLineSync();

  var random = Random();
  int index = random.nextInt(emojis.length);

  String emoji = emojis[index];
  String description = descriptions[index];
  int energy = energies[index];

  print('\nПривет, $name! Твое настроение: $emoji $description (энергия: $energy/10)');

  // юникод для одного эмодзи настроения
  var characters = chars.Characters(emoji);
  var graphemes = characters.toList();
  print('Юникод: ${_formatCodePoints(graphemes)}');

  // Дополнительная часть: анализ сложных эмодзи
  print('\nХотите проанализировать сложные эмодзи? (да/нет)');
  String? answer = stdin.readLineSync()?.toLowerCase();
  if (answer == 'да' || answer == 'yes' || answer == 'д') {
    stdout.write('Введите строку с эмодзи (можно несколько): ');
    String? input = stdin.readLineSync();
    if (input != null && input.isNotEmpty) {
      analyzeEmojiString(input);
