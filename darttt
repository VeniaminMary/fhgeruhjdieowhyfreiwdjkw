    }
  }
}

// форматирование юникода для списка графем
String _formatCodePoints(List<String> graphemes) {
  List<String> result = [];
  for (var grapheme in graphemes) {
    for (int codePoint in grapheme.runes) {
      String hex = codePoint.toRadixString(16).toUpperCase().padLeft(6, '0');
      result.add('U+$hex');
    }
  }
  return result.join(' ');
}

// анализ строки с эмодзи
void analyzeEmojiString(String input) {
  // 1. Количество 16-битных единиц (UTF-16 code units) = длина строки в Dart
  int utf16Units = input.length;

  // 2. Количество кодовых точек (Unicode code points)
  int codePoints = input.runes.length;

  // 3. Количество реальных символов (графемных кластеров)
  int graphemeClusters = chars.Characters(input).length;

  print('\n--- Результаты анализа ---');
  print('Введённая строка: "$input"');
  print('1) 16-битных единиц (str.length): $utf16Units');
  print('2) Кодовых точек (runes.length): $codePoints');
  print('3) Реальных символов (графем): $graphemeClusters');

  // Демонстрация разницы на примере
  print('\n--- Демонстрация различий ---');
  print('Обычная длина строки (UTF-16) = $utf16Units');
  print('Длина через руны (code points) = $codePoints');
  print('Длина через графемные кластеры = $graphemeClusters');
  if (utf16Units != graphemeClusters) {
    print('👉 Разница объясняется тем, что некоторые эмодзи (например, семейные, с модификаторами цвета кожи, флаги) состоят из нескольких кодовых точек, но визуально отображаются как один символ.');
  } else {
    print('👉 В этой строке каждый символ занимает ровно одну 16-битную единицу.');
  }

  // Вывод юникода для каждого символа (графемы)
  print('\n--- Юникод каждого символа ---');
  final characters = chars.Characters(input);
  int idx = 1;
  for (var grapheme in characters) {
    // Формируем список кодовых точек для графемы
    List<String> codePointsList = [];
    for (int cp in grapheme.runes) {
      codePointsList.add('U+${cp.toRadixString(16).toUpperCase().padLeft(6, '0')}');
    }
    print('Символ $idx: "$grapheme" -> ${codePointsList.join(' ')}');
    idx++;
  }
}
